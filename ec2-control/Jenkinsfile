pipeline {
agent any

```
triggers {
    cron('H/10 * * * *')
}

parameters {

    choice(
        name: 'MODE',
        choices: ['MANUAL', 'AUTO'],
        description: 'Manual control or automatic scheduling'
    )

    choice(
        name: 'ACTION',
        choices: ['START', 'STOP', 'REBOOT'],
        description: 'Select action for EC2 instances'
    )

    string(
        name: 'TAG_KEY',
        defaultValue: 'AutoSchedule',
        description: 'EC2 Tag Key'
    )

    string(
        name: 'TAG_VALUE',
        defaultValue: 'true',
        description: 'EC2 Tag Value'
    )

    choice(
        name: 'REGION',
        choices: [
            'ap-south-1',
            'us-east-1',
            'us-west-2',
            'eu-west-1'
        ],
        description: 'Select AWS Region'
    )
}

stages {

    stage('Fetch Instances By Tag') {
        steps {
            withAWS(credentials: 'aws-jenkins-creds', region: "${params.REGION}") {
                script {

                    echo "Searching instances with tag ${params.TAG_KEY}=${params.TAG_VALUE}"

                    env.INSTANCE_IDS = sh(
                        script: """
                        aws ec2 describe-instances \
                        --filters "Name=tag:${params.TAG_KEY},Values=${params.TAG_VALUE}" \
                        --query "Reservations[].Instances[].InstanceId" \
                        --output text
                        """,
                        returnStdout: true
                    ).trim()

                    if (!env.INSTANCE_IDS) {
                        error "No instances found with tag ${params.TAG_KEY}=${params.TAG_VALUE}"
                    }

                    echo "Instances Found: ${env.INSTANCE_IDS}"
                }
            }
        }
    }

    stage('Execute Logic') {
        steps {
            withAWS(credentials: 'aws-jenkins-creds', region: "${params.REGION}") {
                script {

                    if (params.MODE == 'MANUAL') {

                        echo "Manual Mode: ${params.ACTION}"

                        if (params.ACTION == 'START') {

                            sh "aws ec2 start-instances --instance-ids ${env.INSTANCE_IDS}"

                        } else if (params.ACTION == 'STOP') {

                            sh "aws ec2 stop-instances --instance-ids ${env.INSTANCE_IDS}"

                        } else if (params.ACTION == 'REBOOT') {

                            echo "Performing HARD reboot"

                            sh "aws ec2 stop-instances --instance-ids ${env.INSTANCE_IDS}"
                            sh "aws ec2 wait instance-stopped --instance-ids ${env.INSTANCE_IDS}"
                            sh "aws ec2 start-instances --instance-ids ${env.INSTANCE_IDS}"
                        }

                    } else {

                        echo "AUTO scheduling mode"

                        CURRENT_HOUR = sh(
                            script: "date +%H",
                            returnStdout: true
                        ).trim()

                        echo "Current hour: ${CURRENT_HOUR}"

                        sh """
                        aws ec2 describe-instances \
                        --instance-ids ${env.INSTANCE_IDS} \
                        --query 'Reservations[].Instances[].{ID:InstanceId,State:State.Name,Start:Tags[?Key==`StartTime`]|[0].Value,Stop:Tags[?Key==`StopTime`]|[0].Value}' \
                        --output json > instances.json
                        """

                        def instances = readJSON file: 'instances.json'

                        for (i in instances) {

                            def id = i.ID
                            def state = i.State
                            def start = i.Start
                            def stop = i.Stop

                            echo "Instance ${id} | state=${state} | start=${start} | stop=${stop}"

                            def desiredState = "stopped"

                            if (CURRENT_HOUR >= start && CURRENT_HOUR < stop) {
                                desiredState = "running"
                            }

                            echo "Desired state: ${desiredState}"

                            if (state == desiredState) {

                                echo "SKIP: instance already in correct state"

                            } else if (desiredState == "running") {

                                echo "Starting instance ${id}"
                                sh "aws ec2 start-instances --instance-ids ${id}"

                            } else {

                                echo "Stopping instance ${id}"
                                sh "aws ec2 stop-instances --instance-ids ${id}"

                            }

                        }

                    }
                }
            }
        }
    }

    stage('Verify Status') {
        steps {
            withAWS(credentials: 'aws-jenkins-creds', region: "${params.REGION}") {

                echo "Checking final instance status..."

                sh """
                aws ec2 describe-instances \
                --instance-ids ${env.INSTANCE_IDS} \
                --query "Reservations[].Instances[].State.Name" \
                --output table
                """
            }
        }
    }
}
```

}
