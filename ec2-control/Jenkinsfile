pipeline {
agent any

triggers {
    cron('H/10 * * * *')
}

parameters {

    choice(
        name: 'MODE',
        choices: ['MANUAL', 'AUTO'],
        description: 'Manual control or automatic scheduling'
    )

    choice(
        name: 'ACTION',
        choices: ['START', 'STOP', 'REBOOT'],
        description: 'Action to perform in MANUAL mode'
    )

    string(
        name: 'TAG_KEY',
        defaultValue: 'AutoSchedule',
        description: 'EC2 Tag Key'
    )

    string(
        name: 'TAG_VALUE',
        defaultValue: 'true',
        description: 'EC2 Tag Value'
    )

    choice(
        name: 'REGION',
        choices: [
            'ap-south-1',
            'us-east-1',
            'us-west-2',
            'eu-west-1'
        ],
        description: 'AWS Region'
    )
}

stages {

    stage('Fetch Instance Data') {
        steps {
            withAWS(credentials: 'aws-jenkins-creds', region: "${params.REGION}") {
                script {

                    echo "Fetching instance data with tag ${params.TAG_KEY}=${params.TAG_VALUE}"

                    env.INSTANCE_DATA = sh(
                        script: """
                        aws ec2 describe-instances \
                        --filters Name=tag:${params.TAG_KEY},Values=${params.TAG_VALUE} \
                        --query "Reservations[].Instances[].[
                            InstanceId,
                            State.Name,
                            Tags[?Key=='StartTime']|[0].Value,
                            Tags[?Key=='StopTime']|[0].Value
                        ]" \
                        --output text
                        """,
                        returnStdout: true
                    ).trim()

                    if (!env.INSTANCE_DATA) {
                        error "No instances found with tag ${params.TAG_KEY}=${params.TAG_VALUE}"
                    }

                    echo "Instance Data:"
                    echo "${env.INSTANCE_DATA}"
                }
            }
        }
    }

    stage('Execute Logic') {
        steps {
            withAWS(credentials: 'aws-jenkins-creds', region: "${params.REGION}") {
                script {

                    def CURRENT_HOUR = sh(
                        script: "date +%H",
                        returnStdout: true
                    ).trim()

                    echo "Current hour: ${CURRENT_HOUR}"

                    def lines = env.INSTANCE_DATA.split("\\n")

                    for (line in lines) {

                        def parts = line.trim().split()

                        def id = parts[0]
                        def state = parts[1]
                        def start = parts.size() > 2 ? parts[2] : "00"
                        def stop = parts.size() > 3 ? parts[3] : "24"

                        echo "Instance ${id} | state=${state} | start=${start} | stop=${stop}"

                        if (params.MODE == 'MANUAL') {

                            echo "Manual Mode"

                            if (params.ACTION == 'START') {

                                sh "aws ec2 start-instances --instance-ids ${id}"

                            } else if (params.ACTION == 'STOP') {

                                sh "aws ec2 stop-instances --instance-ids ${id}"

                            } else if (params.ACTION == 'REBOOT') {

                                echo "Hard reboot"

                                sh "aws ec2 stop-instances --instance-ids ${id}"
                                sh "aws ec2 wait instance-stopped --instance-ids ${id}"
                                sh "aws ec2 start-instances --instance-ids ${id}"
                            }

                        } else {

                            echo "AUTO scheduling mode"

                            def desiredState = "stopped"

                            if (CURRENT_HOUR >= start && CURRENT_HOUR < stop) {
                                desiredState = "running"
                            }

                            echo "Desired state: ${desiredState}"

                            if (state == desiredState) {

                                echo "SKIP: instance already correct"

                            } else if (desiredState == "running") {

                                echo "Starting ${id}"
                                sh "aws ec2 start-instances --instance-ids ${id}"

                            } else {

                                echo "Stopping ${id}"
                                sh "aws ec2 stop-instances --instance-ids ${id}"

                            }

                        }
                    }
                }
            }
        }
    }

    stage('Verify Status') {
        steps {
            withAWS(credentials: 'aws-jenkins-creds', region: "${params.REGION}") {

                echo "Final instance status"

                sh """
                aws ec2 describe-instances \
                --filters Name=tag:${params.TAG_KEY},Values=${params.TAG_VALUE} \
                --query "Reservations[].Instances[].State.Name" \
                --output table
                """

            }
        }
    }
}

}
