pipeline {
    agent any

    parameters {
        choice(
            name: 'ACTION',
            choices: ['START', 'STOP', 'REBOOT'],
            description: 'Select action for EC2 instance'
        )

        string(
            name: 'INSTANCE_ID',
            defaultValue: '',
            description: 'Enter EC2 Instance ID (e.g., i-0123456789abcdef0)'
        )

        choice(
            name: 'REGION',
            choices: [
                'ap-south-1',
                'us-east-1',
                'us-west-2',
                'eu-west-1'
            ],
            description: 'Select AWS Region'
        )
    }

    stages {

        stage('Validate Input') {
            steps {
                script {
                    if (!params.INSTANCE_ID?.trim()) {
                        error "INSTANCE_ID cannot be empty!"
                    }
                }
            }
        }

        stage('EC2 Lifecycle Control') {
            steps {
                withAWS(credentials: 'aws-jenkins-creds', region: "${params.REGION}") {

                    script {

                        CURRENT_STATE = sh(
                            script: """
                            aws ec2 describe-instances \
                            --instance-ids ${params.INSTANCE_ID} \
                            --query "Reservations[].Instances[].State.Name" \
                            --output text
                            """,
                            returnStdout: true
                        ).trim()

                        echo "Current Instance State: ${CURRENT_STATE}"

                        if (params.ACTION == 'START') {

                            if (CURRENT_STATE == 'running') {
                                echo "Instance already running."
                            } else {
                                sh "aws ec2 start-instances --instance-ids ${params.INSTANCE_ID}"
                            }

                        } else if (params.ACTION == 'STOP') {

                            if (CURRENT_STATE == 'stopped') {
                                echo "Instance already stopped."
                            } else {
                                sh "aws ec2 stop-instances --instance-ids ${params.INSTANCE_ID}"
                            }

                        } else if (params.ACTION == 'REBOOT') {

                            sh "aws ec2 reboot-instances --instance-ids ${params.INSTANCE_ID}"
                        }
                    }
                }
            }
        }

        stage('Final Status') {
            steps {
                withAWS(credentials: 'aws-jenkins-creds', region: "${params.REGION}") {
                    sh """
                    aws ec2 describe-instances \
                    --instance-ids ${params.INSTANCE_ID} \
                    --query "Reservations[].Instances[].State.Name" \
                    --output text
                    """
                }
            }
        }
    }
}